# ============================================================
# SKY STORE — Configuration Stripe
# ============================================================
# Copie ce fichier en .env et remplis les valeurs

# --- Stripe Keys (test) ---
# Obtiens-les sur: https://dashboard.stripe.com/test/apikeys
# IMPORTANT: ne jamais partager ces cles en clair dans les tickets/commentaires.
STRIPE_SECRET_KEY=ROTATE_REQUIRED_SET_NEW_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=ROTATE_REQUIRED_SET_NEW_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=ROTATE_REQUIRED_SET_NEW_WEBHOOK_SECRET

# --- Mode ---
# true = simulation (paiement instantly confirme, sans Stripe)
# false = vrai Stripe test (necessite les cles ci-dessus)
MOCK_STRIPE=true

# --- Application ---
PORT=3000
NODE_ENV=development
SESSION_SECRET=change_this_to_a_random_string_in_production
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DEFAULT_TENANT_ID=public
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
# true = impose l'email admin bootstrap pour la premiere inscription admin
# false = inscription publique normale (recommande pour URL de test publique)
REQUIRE_BOOTSTRAP_ADMIN_SIGNUP=false
# En single-tenant, garder false pour eviter qu'un sous-domaine tunnel
# change le tenant et casse la connexion admin.
ENABLE_SUBDOMAIN_TENANT=false

# --- Email (mode reel, independant de Stripe) ---
# Option A: SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Option B: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Sky Store

# URL publique utilisee dans les emails (liens /account et telechargements)
BASE_URL=http://localhost:3000

# URL publique stable pour le webhook Stripe.
# Recommande: tunnel nomme (ou domaine fixe), pas un lien trycloudflare ephemere.
# Exemple: https://payments.sky-store.example.com
STRIPE_WEBHOOK_PUBLIC_BASE_URL=

# ============================================================
# INSTRUCTIONS POUR PASSER EN MODE STRIPE REEL (TEST):
# 1. Remplace les valeurs ci-dessus par tes vraies cles test
# 2. Change MOCK_STRIPE=false
# 3. Definis STRIPE_WEBHOOK_PUBLIC_BASE_URL avec une URL stable
# 4. Configure le webhook Stripe sur ton dashboard:
#    URL: ${STRIPE_WEBHOOK_PUBLIC_BASE_URL}/api/webhook/stripe
#    Evenements: checkout.session.completed
# 5. Redemarre le serveur
# ============================================================
